# Required for NextAuth. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Set when serving under a path (e.g. /dewey behind Caddy). Must match proxy path; rebuild after changing.
# Example (Tailscale): https://home-server.xxxx.ts.net/dewey
# NEXT_PUBLIC_BASE_PATH=/dewey
# NEXTAUTH_URL=https://home-server.your-tailnet.ts.net/dewey

# Optional: public URL where the browser can GET RAGDoll documents (/fetch/...). Use when RAGDoll listens on an internal port (e.g. 9042) but browsers only reach your host via HTTPS without a port (Tailscale terminates TLS and forwards to Caddy on 8083—you do not put :8083 in this URL).
# Point this at a Caddy path that reverse_proxies to 127.0.0.1:9042 with path preserved (see handle_path /rag-api/*). Rebuild after changing.
# Example: https://home-server.xxxx.ts.net/rag-api   (no trailing slash; same scheme/host as Dewey, different path)
# NEXT_PUBLIC_RAG_DOCUMENT_BASE=

# PostgreSQL connection string for user and settings storage (required).
# Example: postgresql://user:password@localhost:5432/dewey
DATABASE_URL=

# Optional: set to enable each provider. Omit a block to disable that provider.

# Apple (Sign in with Apple)
# Create a Services ID and Key in Apple Developer: Certificates, Identifiers & Profiles
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Google
# Create OAuth 2.0 credentials in Google Cloud Console
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft (Azure AD / Entra ID)
# Register an application and create a client secret in Azure Portal
AUTH_MICROSOFT_ID=
AUTH_MICROSOFT_SECRET=

# Optional: default settings applied to every new account (setup + register).
# Omit a variable to leave that setting unset for new users.
DEWEY_DEFAULT_OLLAMA_URL=
DEWEY_DEFAULT_RAG_SERVER_URL=
DEWEY_DEFAULT_RAG_THRESHOLD=
# Comma-separated list, e.g. ed-leadership,mufsd,serv_leadership
DEWEY_DEFAULT_RAG_COLLECTIONS=
# Default Ollama model name for new users (e.g. llama3.2, qwen2.5:7b).
DEWEY_DEFAULT_MODEL=
# Log each RAG proxy call to the server process stdout (Next/Docker/PM2 logs). Also enabled when DEWEY_DEBUG_CONSOLE=true.
DEWEY_RAG_SERVER_LOG=false
# Show debug messages in console (true/false). Can also be toggled in Admin → Settings.
DEWEY_DEBUG_CONSOLE=false

# Claude API key for coaching engine (Layer 2). Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=